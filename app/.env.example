# Vercel / local — copy to .env.local and fill in values
# All NEXT_PUBLIC_ vars are exposed to the browser.

# WalletConnect Cloud project ID — get one free at https://cloud.walletconnect.com
# Without a real ID, injected wallets (MetaMask) still work; WalletConnect QR won't.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Arc Testnet contract addresses (already hardcoded in lib/contracts.ts — keep in sync if you redeploy)
NEXT_PUBLIC_ARENA_FACTORY=0x13a38e7C2bA5AFA76a1AC21Eaef9f4DEA293FEBe
NEXT_PUBLIC_REPUTATION_NFT=0x953f508CdC9DC4FaA17D898a5e65A91a262F6607
NEXT_PUBLIC_USDC=0x3600000000000000000000000000000000000000

# Arc Testnet network config
NEXT_PUBLIC_ARC_RPC=https://rpc.testnet.arc.network
NEXT_PUBLIC_CHAIN_ID=5042002
